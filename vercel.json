{
  "version": 2,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.1",
      "includeFiles": "**/*.php"
    }
  },
  "routes": [
    {
      "src": "/public/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/uploads/$1"
    },
    {
      "src": "/api/((?!main.php).*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/main.php"
    }
  ],
  "env": {
    "DB_CHARSET": "utf8mb4"
  }
}
